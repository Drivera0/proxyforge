# Server
HOST=0.0.0.0
PORT=8000

# Upstream target URL to proxy requests to
UPSTREAM_URL=https://example.com

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: API key for authenticated proxy access
API_KEY=

# Optional: Request timeout in seconds
REQUEST_TIMEOUT=30

# Optional: Max concurrent connections
MAX_CONNECTIONS=100
